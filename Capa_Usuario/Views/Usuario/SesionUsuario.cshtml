@model IEnumerable<Capa_Entidad.Seguridad_ENT.TablasSql.Usuario_E>
@{
    ViewBag.Title = "Sesión de Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 position-relative">
    <div class="row justify-content-center align-items-center">

        <!-- Card principal -->
        <div class="col-lg-5 col-md-8">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-success text-white text-center py-4">
                    <h4 class="mb-0">
                        <i class="bi bi-person-circle me-2"></i>
                        Manual de Usuario
                    </h4>
                </div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center" style="min-height: 200px;">
                    <p class="text-muted mb-4 text-center">
                        Descargue el manual para conocer todas las funcionalidades del sistema.
                    </p>
                    <a href="@Url.Action("Manual", "Documentos")" class="btn btn-warning btn-lg shadow-sm">
                        <i class="bi bi-download me-2"></i>
                        <strong>Descargar Manual</strong>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
<div style="position: fixed; top: 5rem; right: 1rem; z-index: 1050;">
    <div style="display: flex; align-items: center; gap: 0.5rem;">
        <i class="bi bi-person-circle" style="font-size: 1.5rem; color: white;"></i>
        <h6 class="mb-0" style="color: white;">@ViewBag.NombreUsuario</h6>
    </div>
</div>



<script>
    if ('@ViewBag.mensaje' != "") {
        Swal.fire({
            title: "@ViewBag.mensaje",
            icon: "success",
            confirmButtonColor: "#198754"
        });
    }
</script>

