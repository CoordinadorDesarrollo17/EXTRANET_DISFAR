@model List<Capa_Entidad.Transacciones_ENT.TablasSql.Factura_E>
@using Capa_Entidad.Seguridad_ENT.TablasSql
@{
    ViewBag.Title = "Consultar Comprobantes";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var listaClientes = (List<Capa_Entidad.SociosNegocios_ENT.TablasSql.Clientes_E>)ViewBag.Clientes;
}



<div class="row">
    <div class="col-lg-12 pt-4">
        <div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
            <div class="row px-3 pt-3"><h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3></div>
            <div class="row px-3 pt-3">
                <div class="col-lg-12">
                    <div class="d-flex align-items-start gap-2">
                        <a style="float:left;" href="@Url.Action("SesionUsuario", "Usuario")" class="btn btn-secondary">
                            <i class="icon-arrow-bold-left"></i>
                            <span>Regresar</span>
                        </a>
                        <button type="button" class="btn btn-warning" onclick="abrirModalFiltrarComprobantes()">
                            <i class="bi bi-filter"></i> Consultar Comprobante
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white px-3 py-3 align-items-center">
            <div class="row justify-content-center">
                <div class="col">
                    <div class="table-responsive">
                        <div id="div_listado" class="container-fluid p-3">
                            <table id="tablaComprobantes" class="table table-hover">
                                <thead class="text-center encabezado-verde">
                                    <tr>
                                        <th class="text-center">Codigo</th>
                                        <th class="text-start">Cliente</th>
                                        <th class="text-center">Numero</th>
                                        <th class="text-center">Fecha</th>
                                        <th class="text-center">Total</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {

                                        <tr>
                                            <td class="text-center">@item.CardCode</td>
                                            <td class="text-start">@item.CardName</td>
                                            <td class="text-center">@item.Correlativo</td>
                                            <td class="text-center">@item.DocDate</td>
                                            <td class="text-center">@item.DocTotal.ToString("N2")</td>
                                            <td class="text-center">
                                                <button type="button"
                                                        class="btn btn-sm btn-primary d-inline-flex align-items-center gap-1"
                                                        onclick="verDetalleComprobante(@item.DocEntry)">
                                                    <i class="bi bi-eye"></i> Ver
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalFiltroComprobantes" tabindex="-1" aria-labelledby="modalFiltroComprobantesLabel" aria-hidden="true" data-bs-focus="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-green-gradient">
                <h5 class="modal-title" id="modalFiltroComprobantesLabel"><b>Consultar Comprobantes</b></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="frm_BusquedaComprobantes" method="get">
                    <div class="form-group mb-3">
                        @if (ViewBag.Tipo != 3)
                        {
                            <div class="mb-3">
                                <label for="CardCode_filtro" class="form-label">Cliente*</label>
                                <select id="CardCode_filtro" name="CardCode" class="cls-select">
                                    <option value="">Seleccionar cliente</option>
                                    @foreach (var obj in listaClientes)
                                    {
                                        <option value="@obj.CardCode"> @obj.CardCode - @obj.CardName</option>
                                    }
                                </select>
                            </div>
                            <div id="contenedorResultado" class="mt-3"></div>
                        }
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Fecha Inicio</label>
                            <input class="form-control" type="date" name="FechaInicio" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fecha Fin</label>
                            <input class="form-control" type="date" name="FechaFin" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Serie</label>
                            <input class="form-control" type="text" name="Correlativo" placeholder="Ej.: F003" autocomplete="off"
                                   title="Solo letras, números, espacios, acentos, apóstrofe, guion y punto." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Número</label>
                            <input class="form-control" type="text" name="Correlativo2" placeholder="Número" autocomplete="off"
                                   title="Solo letras, números, espacios, acentos, apóstrofe, guion y punto." />
                        </div>
                    </div>

                    <div class="text-center">
                        <div class="text-center">
                            <button type="button" class="btn btn-danger" onclick="buscarComprobantes()">
                                <i class="bi bi-search"></i> Buscar
                            </button>
                            <button type="button" class="btn btn-secondary" onclick="buscarComprobantes(true)">Cancelar</button>
                        </div>
                    </div>
                    <p class="text-muted mt-2">*Campos opcionales, considera coincidencias</p>

                </form>


            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDetalleComprobante" tabindex="-1" aria-labelledby="modalDetalleComprobanteLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" id="detalleComprobanteContent">
            <!-- Aquí se cargará el contenido por AJAX -->
        </div>
    </div>
</div>

@section Scripts{

    <script>
    // Mensaje seguro desde ViewBag
    let mensaje = @Html.Raw(Json.Encode(ViewBag.mensaje ?? ""));
    if (mensaje) {
        Swal.fire(mensaje);
    }

    inicializarSlimSelects('cls-select');

    function inicializarTablaComprobantes() {
        if ($.fn.DataTable.isDataTable('#tablaComprobantes')) {
            $('#tablaComprobantes').DataTable().destroy();
        }

        $('#tablaComprobantes').DataTable({
            language: {
                url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
            },
            responsive: true,
            pageLength: 10
        });
    }

    $(document).ready(function () {
        inicializarTablaComprobantes();
    });

    function abrirModalFiltrarComprobantes() {
        $('#modalFiltroComprobantes').modal('show');
    }
    </script>

    <script>
    let slimCliente = null;

    function inicializarSlimSelectCliente() {
        if (slimCliente instanceof SlimSelect) {
            slimCliente.destroy();
        }

        const select = document.getElementById('CardCode_filtro');
        if (select) {
            slimCliente = new SlimSelect({
                select: '#CardCode_filtro'
            });
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        inicializarSlimSelectCliente();
    });

    async function buscarComprobantes(reset = false) {

        const cardCodeInput = document.getElementById("CardCode_filtro");

        const params = new URLSearchParams({
            CardCode: cardCodeInput ? (reset ? "" : cardCodeInput.value || "") : "",
            FechaInicio: reset ? "" : document.querySelector('input[name="FechaInicio"]')?.value || "",
            FechaFin: reset ? "" : document.querySelector('input[name="FechaFin"]')?.value || "",
            Correlativo: reset ? "" : document.querySelector('input[name="Correlativo"]')?.value || "",
            Correlativo2: reset ? "" : document.querySelector('input[name="Correlativo2"]')?.value || ""
        });

        if (!reset && cardCodeInput && (!params.get("CardCode") || !params.get("FechaInicio") || !params.get("FechaFin"))) {
            Swal.fire({
                icon: 'warning',
                title: 'Campos obligatorios',
                text: 'Debe seleccionar un cliente y un rango de fechas (inicio y fin).',
            });
            return;
        }


        try {
            const response = await fetch(
                '@Url.Action("FiltrarComprobantes", "Documentos")?' + params.toString(),
                { method: 'GET' }
            );

            if (!response.ok) throw new Error("Error al filtrar comprobantes");

            const html = await response.text();
            document.querySelector("#div_listado").innerHTML = html;

            inicializarTablaComprobantes();

            const modalElement = document.getElementById('modalFiltroComprobantes');
            const instance = bootstrap.Modal.getInstance(modalElement) ?? new bootstrap.Modal(modalElement);
            instance.hide();

        } catch (error) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: error.message || 'Ocurrió un error inesperado.'
            });
        }
    }

    function verDetalleComprobante(docEntry) {

        fetch('@Url.Action("DetalleComprobante", "Documentos")?DocEntry=' + encodeURIComponent(docEntry))
            .then(response => {
                if (!response.ok) throw new Error('Error del servidor');
                return response.text();
            })
            .then(html => {

                document.getElementById('detalleComprobanteContent').innerHTML = html;

                const modalEl = document.getElementById('modalDetalleComprobante');
                const modal = new bootstrap.Modal(modalEl);

                modalEl.addEventListener('shown.bs.modal', function () {

                    if ($.fn.DataTable.isDataTable('#tablaDetalleComprobante')) {
                        $('#tablaDetalleComprobante').DataTable().destroy();
                    }

                    $('#tablaDetalleComprobante').DataTable({
                        language: {
                            url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                        },
                        responsive: true,
                        pageLength: 10,
                        pagingType: "full_numbers"
                    });

                }, { once: true });

                modal.show();
            })
            .catch(error => {
                Swal.fire('Error', 'No se pudo cargar el detalle.', 'error');
                console.error(error);
            });
    }
    </script>
}
