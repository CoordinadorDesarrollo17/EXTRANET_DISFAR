        // ==========================================
        // 6. FUNCIÓN VER PDF (NUEVA - CANVAS)
        // ==========================================
        let pdfUrlActual = ''; // Variable global para la descarga

        async function verPDF(ruta) {
            pdfUrlActual = ruta; // Guardar URL para descarga
            console.log("Intentando abrir PDF:", ruta);

            // 1. Mostrar el modal
            const modalElement = document.getElementById("modalVisorPDF");
            const modal = new bootstrap.Modal(modalElement);
            modal.show();

            const container = document.getElementById('pdf-render-container');
            const pdfInfo = document.getElementById('pdfInfo');

            // Limpiar contenedor y mostrar spinner
            container.innerHTML = '<div class="spinner-border text-light mt-5" role="status"><span class="visually-hidden">Cargando...</span></div>';
            pdfInfo.textContent = '';

            try {
                // 2. Cargar documento PDF
                const loadingTask = pdfjsLib.getDocument(ruta);
                const pdf = await loadingTask.promise;

                // Limpiar spinner
                container.innerHTML = '';

                // Mostrar información
                pdfInfo.textContent = `Documento con ${pdf.numPages} página(s)`;

                // 3. ✅ Renderizar TODAS las páginas
                for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
                    await renderizarPaginaProtocolo(pdf, pageNum, container);
                }

            } catch (error) {
                console.error('Error cargando PDF:', error);
                container.innerHTML = '<p class="text-light mt-3"><i class="bi bi-exclamation-triangle"></i> No se pudo cargar el archivo PDF.</p>';
                pdfInfo.textContent = '';
            }
        }

        // Función auxiliar para renderizar cada página
        async function renderizarPaginaProtocolo(pdfDoc, num, container) {
            const page = await pdfDoc.getPage(num);

            // Escala para buena calidad
            const scale = 1.5;
            const viewport = page.getViewport({ scale: scale });

            // Contenedor de la página
            const pageContainer = document.createElement('div');
            pageContainer.className = 'mb-3';
            pageContainer.style.position = 'relative';

            // Agregar etiqueta de número de página si hay más de una
            if (pdfDoc.numPages > 1) {
                const pageLabel = document.createElement('div');
                pageLabel.className = 'badge bg-light text-dark position-absolute top-0 start-50 translate-middle-x mt-2';
                pageLabel.style.zIndex = '10';
                pageLabel.textContent = `Página ${num} de ${pdfDoc.numPages}`;
                pageContainer.appendChild(pageLabel);
            }

            // Crear canvas
            const canvas = document.createElement('canvas');
            canvas.style.boxShadow = '0 0 10px rgba(0,0,0,0.5)';
            canvas.style.backgroundColor = 'white';
            canvas.height = viewport.height;
            canvas.width = viewport.width;

            pageContainer.appendChild(canvas);
            container.appendChild(pageContainer);

            // Renderizar
            const renderContext = {
                canvasContext: canvas.getContext('2d'),
                viewport: viewport
            };
            await page.render(renderContext).promise;
        }

        // ==========================================
        // FUNCIÓN PARA DESCARGAR PDF
        // ==========================================
        function descargarPDF() {
            if (!pdfUrlActual) {
                Swal.fire('Error', 'No hay ningún PDF cargado para descargar.', 'error');
                return;
            }

            // Crear enlace temporal para descarga
            const link = document.createElement('a');
            link.href = pdfUrlActual;
            link.download = 'Protocolo_' + new Date().getTime() + '.pdf';
            link.target = '_blank';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);

            // Mensaje de confirmación
            Swal.fire({
                icon: 'success',
                title: 'Descarga iniciada',
                text: 'El archivo PDF se está descargando.',
                timer: 2000,
                showConfirmButton: false
            });
        }

        // ==========================================
        // ✅ BÚSQUEDA EN TIEMPO REAL PARA PROTOCOLOS
        // ==========================================
        let timeoutBusquedaProtocolo = null;

        function configurarBusquedaRapidaProtocolos() {
            // Evento para Código
 $('#filtroCodigo').on('keyup', function(e) {
        if (e.key === 'Enter') {
      ejecutarBusquedaRapidaProtocolos();
  } else {
     clearTimeout(timeoutBusquedaProtocolo);
timeoutBusquedaProtocolo = setTimeout(() => {
       ejecutarBusquedaRapidaProtocolos();
   }, 800);
 }
  });

    // Evento para Descripción
    $('#filtroDesc').on('keyup', function(e) {
     if (e.key === 'Enter') {
   ejecutarBusquedaRapidaProtocolos();
   } else {
      clearTimeout(timeoutBusquedaProtocolo);
 timeoutBusquedaProtocolo = setTimeout(() => {
           ejecutarBusquedaRapidaProtocolos();
 }, 800);
        }
    });

    // Evento para Lote
    $('#filtroLote').on('keyup', function(e) {
        if (e.key === 'Enter') {
  ejecutarBusquedaRapidaProtocolos();
 } else {
  clearTimeout(timeoutBusquedaProtocolo);
            timeoutBusquedaProtocolo = setTimeout(() => {
     ejecutarBusquedaRapidaProtocolos();
   }, 800);
    }
    });
}

async function ejecutarBusquedaRapidaProtocolos() {
    const codigo = $('#filtroCodigo').val().trim();
    const desc = $('#filtroDesc').val().trim();
  const lote = $('#filtroLote').val().trim();
    
    // Si todos están vacíos, limpiar
    if (!codigo && !desc && !lote) {
        limpiarBusquedaRapidaProtocolos();
  return;
    }

    try {
  // Mostrar indicadores
        $('#indicadorCodigo, #indicadorDesc, #indicadorLote').removeClass('d-none');
        
// Deshabilitar inputs
 $('#filtroCodigo, #filtroDesc, #filtroLote').prop('disabled', true);

   const params = new URLSearchParams({
     ItemCode: codigo,
     ItemName: desc,
  DistNumber: lote
});

      const response = await fetch(`/Documentos/FiltrarProtocolos?${params.toString()}`);
        
 if (!response.ok) throw new Error("Error en el servidor");

        const html = await response.text();
 document.querySelector("#div_listado").innerHTML = html;
        initDataTable();

    } catch (error) {
 console.error(error);
    Swal.fire({
 icon: 'error',
 title: 'Error',
   text: 'No se pudo realizar la búsqueda.',
   toast: true,
            position: 'top-end',
            showConfirmButton: false,
   timer: 3000
  });
    } finally {
        // Ocultar indicadores y habilitar inputs
  $('#indicadorCodigo, #indicadorDesc, #indicadorLote').addClass('d-none');
  $('#filtroCodigo, #filtroDesc, #filtroLote').prop('disabled', false);
    }
}

function limpiarBusquedaRapidaProtocolos() {
    $('#filtroCodigo').val('');
    $('#filtroDesc').val('');
    $('#filtroLote').val('');
window.location.reload();
}
    </script>
