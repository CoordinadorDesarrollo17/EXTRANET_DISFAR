    });

    try {
        const response = await fetch(`/Documentos/FiltrarProtocolos?${params.toString()}`);
 const html = await response.text();
        document.querySelector("#div_listado").innerHTML = html;
    initDataTable();
        const el = document.getElementById('modalProtocolo');
        const modal = bootstrap.Modal.getInstance(el);
if (modal) modal.hide();
    } catch (e) {
 console.error(e);
      Swal.fire({
      icon: 'error',
title: 'Error',
   text: 'No se pudo filtrar.',
