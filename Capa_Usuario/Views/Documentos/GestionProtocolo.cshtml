@model List<Capa_Entidad.Inventario_ENT.TablasSql.Protocolos_E>
@{
    ViewBag.Title = "Gestión de Protocolos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    table {
        text-align: center;
    }

    td {
        padding: 10px;
        font-size: 14px;
    }
    /* Estilo para opción deseleccionar en SlimSelect */
    .ss-main .ss-single-selected .ss-deselect {
        margin-left: 5px;
        color: #dc3545 !important;
        cursor: pointer;
    }

    /* Estilo para botón deshabilitado (sin PDF) */
    .btn-outline-secondary:disabled {
        cursor: not-allowed !important;
        opacity: 0.6;
        background-color: #f8f9fa;
        border-color: #dee2e6;
        color: #6c757d;
    }

        .btn-outline-secondary:disabled:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
            color: #6c757d;
        }

    .ts-dropdown {
        z-index: 2000 !important;
    }
</style>

<div class="row">
    <div class="col-lg-12 pt-4">
        <div class="border-cabecera-seccion bg-cobefar-degradado-1 pb-2">
            <div class="row px-3 pt-3"><h3 class="titulo-seccion">@ViewBag.Title.ToUpper()</h3></div>
            <div class="row px-3 pt-3">
                <div class="col-lg-12">
                    <div class="d-flex flex-wrap align-items-start gap-2">
                        <a style="float:left;" href="@Url.Action("GestionDocumentos", "Documentos")" class="btn btn-secondary">
                            <i class="icon-arrow-bold-left"></i>
                            <span>Regresar</span>
                        </a>

                        <button type="button" class="btn btn-primary" onclick="abrirModalCrearProtocolo()">
                            <i class="bi bi-file-earmark-plus"></i> Nuevo Protocolo
                        </button>

                        <button type="button" class="btn btn-info text-white" onclick="abrirModalReporte()">
                            <i class="bi bi-file-earmark-bar-graph"></i> Reporte
                        </button>

                        <button type="button" id="btn_filtrar" class="btn btn-light" onclick="abrirModalFiltros()">
                            <i class="bi bi-filter"></i> Filtrar
                        </button>
                    </div>
                </div>
            </div>
        </div>


        <div class="container-fluid my-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
     <label for="filtroCodigo" class="form-label text-muted small mb-1">
  <i class="bi bi-search"></i> Código
   <span id="indicadorCodigo" class="spinner-border spinner-border-sm text-primary ms-2 d-none" role="status"></span>
  </label>
         <input type="text" class="form-control form-control-sm" id="filtroCodigo" placeholder="Escriba el código...">
        </div>

        <div class="col-md-3">
    <label for="filtroDesc" class="form-label text-muted small mb-1">
                <i class="bi bi-search"></i> Descripción
          <span id="indicadorDesc" class="spinner-border spinner-border-sm text-primary ms-2 d-none" role="status"></span>
            </label>
            <input type="text" class="form-control form-control-sm" id="filtroDesc" placeholder="Escriba la descripción...">
        </div>

        <div class="col-md-3">
  <label for="filtroLote" class="form-label text-muted small mb-1">
        <i class="bi bi-search"></i> Lote
                <span id="indicadorLote" class="spinner-border spinner-border-sm text-primary ms-2 d-none" role="status"></span>
      </label>
         <input type="text" class="form-control form-control-sm" id="filtroLote" placeholder="Escriba el lote...">
        </div>

        <div class="col-md-2">
   <button type="button" class="btn btn-sm btn-outline-secondary w-100" onclick="limpiarBusquedaRapidaProtocolos()">
   <i class="bi bi-x-circle"></i> Limpiar
            </button>
        </div>
    </div>
</div>


        <div class="bg-white px-3 py-3 align-items-center">
            <div class="row justify-content-center">
                <div class="col">
                    <div class="table-responsive">
                        <div id="div_listado" class="container-fluid p-3">
                            <table id="tablaProtocolos" class="table table-hover align-middle">
                                <thead class="encabezado-verde text-center">
                                    <tr>
                                        <th class="text-center" style="min-width: 120px;">Codigo</th>
                                        <th class="text-start" style="min-width: 180px;">Descripcion</th>
                                        <th class="text-center" style="min-width: 100px;">Lote</th>
                                        <th class="text-center" style="min-width: 120px;">Usuario</th>
                                        <th class="text-center" style="min-width: 140px;">Fecha Carga</th>
                                        <th class="text-center" style="min-width: 200px;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var p in Model)
                                        {
                                            <tr>
                                                <td class="text-center">@p.ItemCode</td>
                                                <td class="text-start">@p.ItemName</td>
                                                <td class="text-center">@p.DistNumber</td>
                                                <td class="text-center">@p.OpCarga</td>
                                                <td class="text-center">@p.TiempoCarga.ToString("yyyy-MM-dd HH:mm")</td>
                                                <td class="text-center">
                                                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                                                        @if (!string.IsNullOrWhiteSpace(p.RutaArchivo))
                                                        {
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-primary"
                                                                    onclick="verPDF('@Url.Action("DocumentoProtocoloPDF", "Documentos", new { id = p.ItemCode, lote = p.DistNumber })')">
                                                                <i class="bi bi-eye"></i> Ver
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-secondary"
                                                                    disabled
                                                                    title="No existe documento cargado">
                                                                <i class="bi bi-eye-slash"></i> Ver
                                                            </button>
                                                        }

                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-danger ms-1"
                                                                onclick="eliminarProtocolo('@p.ItemCode', '@p.DistNumber',this)">
                                                            <i class="bi bi-trash"></i> Eliminar
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="modalCrearProtocolo" tabindex="-1" aria-labelledby="modalCrearProtocoloLabel" aria-hidden="true" data-bs-focus="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-green-gradient">
                <h5 class="modal-title" id="modalCrearProtocoloLabel">Registrar Protocolo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                @using (Html.BeginForm("GestionProtocolo", "Documentos", FormMethod.Post, new { enctype = "multipart/form-data", id = "formCrearProtocolo" }))
                {
                    <div class="mb-3">
                        <label for="ItemCode" class="form-label">Codigo*</label>
                        <select id="ItemCode" name="ItemCode" class="cls-select"></select>
                    </div>

                    <div class="mb-3">
                        <label for="ItemName" class="form-label">Nombre del artículo</label>
                        <input type="text" name="ItemName" id="ItemName" class="form-control" readonly />
                        <input type="hidden" name="FirmCode" id="FirmCode" />
                    </div>

                    <div class="mb-3">
                        <label for="DistNumber" class="form-label">Lote*</label>
                        <select id="DistNumber" name="DistNumber" class="cls-select">
                            <option value="">Seleccione un lote</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="MnfSerial" class="form-label">Registro del artículo</label>
                        <input type="text" name="MnfSerial" id="MnfSerial" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="ExpDate" class="form-label">Fecha de expiración</label>
                        <input type="date" name="ExpDate" id="ExpDate" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="ArchivoPdf" class="form-label">Archivo PDF*</label>
                        <input type="file" name="ArchivoPdf" id="ArchivoPdf" class="form-control" accept=".pdf" />
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Cargar Archivo
                        </button>
                    </div>
                }
                <p class="mt-3 text-muted">
                    *Debe elegir producto y lote obligatoriamente. Solo se admite PDF (máx. 10 MB).
                </p>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalProtocolo" tabindex="-1" aria-labelledby="modalFiltrosLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-green-gradient">
                <h5 class="modal-title" id="modalFiltrosLabel">Filtrar Protocolos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="filtroCodigo" class="form-label">Código</label>
                        <input type="text" class="form-control" id="filtroCodigo" name="filtroCodigo">
                    </div>
                    <div class="col-md-6">
                        <label for="filtroDesc" class="form-label">Descripcion</label>
                        <input type="text" class="form-control" id="filtroDesc" name="filtroDesc">
                    </div>
                    <div class="col-md-6">
                        <label for="filtroLote" class="form-label">Lote</label>
                        <input type="text" class="form-control" id="filtroLote" name="filtroLote">
                    </div>
                    <div class="col-md-6">
                        <label for="filtroUsuario" class="form-label">Usuario</label>
                        <input type="text" class="form-control" id="filtroUsuario" name="filtroUsuario">
                    </div>
                    <div class="col-md-6">
                        <label for="filtroFechaC" class="form-label">Fecha Carga</label>
                        <input type="date" class="form-control" id="filtroFechaC" name="filtroFechaC">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" onclick="aplicarFiltros(true)">Cancelar</button>
                <button type="button" class="btn btn-success" onclick="aplicarFiltros()">Aplicar Filtros</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVisorPDF" tabindex="-1" aria-labelledby="tituloModalPDF" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="height: 90vh;">
            <div class="modal-header bg-green-gradient text-white">
                <h5 class="modal-title" id="tituloModalPDF">Visor de Protocolo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-0">
                <div id="pdf-render-container" style="width: 100%; height: calc(90vh - 120px); overflow: auto; background-color: #525659; display: flex; flex-direction: column; justify-content: flex-start; align-items: center; padding: 20px;">
                    <!-- Aquí se renderizarán todas las páginas -->
                </div>
            </div>
            <div class="modal-footer bg-light d-flex justify-content-between align-items-center">
                <span id="pdfInfo" class="text-muted small"></span>
                <button type="button" class="btn btn-success btn-sm" onclick="descargarPDF()">
                    <i class="bi bi-download"></i> Descargar PDF
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalReporteProtocolo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-file-earmark-spreadsheet"></i> Reporte de Protocolos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            @using (Html.BeginForm("DescargarProtocolos", "Reportes", FormMethod.Post, new { id = "formReporteProtocolo" }))
            {
                <div class="modal-body">
                    <div class="alert alert-light border" role="alert">
                        <small class="text-muted"><i class="bi bi-info-circle"></i> El rango de fechas no puede exceder los días naturales del mes seleccionado.</small>
                    </div>
                    <div class="mb-3">
                        <label for="txtOpCargaReporte" class="form-label fw-bold">Usuario (Op. Carga)</label>
                        <input type="text" class="form-control" name="txtOpCarga" id="txtOpCargaReporte" placeholder="Ej: JUAN.PEREZ (Opcional)">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="txtFechaInicioReporte" class="form-label fw-bold">Fecha Inicio*</label>
                            <input type="date" class="form-control" name="txtFechaInicio" id="txtFechaInicioReporte" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="txtFechaFinReporte" class="form-label fw-bold">Fecha Fin*</label>
                            <input type="date" class="form-control" name="txtFechaFin" id="txtFechaFinReporte" required>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-download"></i> Descargar Excel</button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap -->
    <script src="/lib/bootstrap/bootstrap.bundle.min.js"></script>

    <!-- TomSelect -->
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>

    <script>
        // ==========================================
        // 0. CONFIGURACIÓN PDF.JS (Al inicio)
        // ==========================================
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

        // ==========================================
        // 1. VARIABLES GLOBALES
        // ==========================================
        let slimArticulo = null;
        let slimLote = null;
        const articuloMap = new Map();

        // Mensaje desde el controlador
        let mensaje = @Html.Raw(Json.Encode(TempData["Mensaje"] ?? ""));
        if (mensaje) {
            Swal.fire(mensaje);
        }

        // ==========================================
        // 2. INICIALIZACIÓN (DOCUMENT READY)
        // ==========================================
        $(document).ready(function () {
            // Inicializar DataTable
            initDataTable();

            // ✅ NUEVO: Configurar búsqueda en tiempo real
            configurarBusquedaRapidaProtocolos();

            // --- EVENTOS MODAL CREAR ---
            $('#modalCrearProtocolo').on('shown.bs.modal', function () {
                inicializarSlimSelectItemCode();
                inicializarSlimSelectLote([]);
            });

            $('#modalCrearProtocolo').on('hidden.bs.modal', function () {
                const form = document.querySelector('#formCrearProtocolo');
                if (form) form.reset();

                limpiarCamposLote();
                $('#ItemName').val('');
                $('#FirmCode').val('');
                $('#ItemCode').val(null).trigger('change');
                $('#DistNumber').empty().val(null);

                if (slimArticulo) { slimArticulo.destroy(); slimArticulo = null; }
                if (slimLote) { slimLote.destroy(); slimLote = null; }

                articuloMap.clear();
            });
        });

       
        let tomArticulo = null;
        const modalCrearProtocolo = document.getElementById('modalCrearProtocolo');

        modalCrearProtocolo.addEventListener('shown.bs.modal', function () {
            inicializarSlimSelectItemCode();
        });


        function inicializarSlimSelectItemCode() {
            const selectElement = document.querySelector('#ItemCode');

            if (tomArticulo) {
                tomArticulo.destroy();
                tomArticulo = null;
            }

            tomArticulo = new TomSelect(selectElement, {
                valueField: 'value',
                labelField: 'itemName',
                searchField: ['value', 'itemName'],
                placeholder: 'Busque código...',
                allowEmptyOption: true,
                maxOptions: 100,

                load: function (query, callback) {
                    if (query.length < 3) {
                        callback([]);
                        return;
                    }

                    const formData = new FormData();
                    formData.append('ItemName', query);
                    formData.append('ItemCode', query);
                    formData.append('FirmCode', '0');

                    fetch('/Documentos/BuscarArticulosAjax', {
                        method: 'POST',
                        body: formData
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (!Array.isArray(data)) return callback([]);

                            articuloMap.clear();

                            data.forEach(item => {
                                articuloMap.set(item.value, {
                                    itemName: item.itemName,
                                    firmCode: item.firmCode
                                });
                            });

                            callback(data);
                        })
                        .catch(() => callback());
                },

                render: {
                    option: function (item, escape) {
                        return `
             <div class="mi-item-lista">
                 <span class="mi-codigo">${escape(item.value)}</span>
                 <span class="mi-nombre">${escape(item.itemName)}</span>
             </div>
         `;
                    },
                    item: function (item, escape) {
                        //  SOLO EL CÓDIGO EN EL SELECCIONADO
                        return `<div style="font-size:16px;">${escape(item.value)}</div>`;
                    },
                    no_results: function () {
                        const query = this.input.value;
                        if (query.length > 0 && query.length < 3) {
                            return `<div class="no-results">Ingrese al menos 3 caracteres</div>`;
                        }
                        return `<div class="no-results">No encontrado</div>`;
                    },
                    loading: function () {
                        return '<div class="loading">Buscando...</div>';
                    }
                },
                onType: function (str) {
                    if (str.length > 0 && str.length < 3) {
                        this.clearOptions();
                        this.open();
                        this.refreshOptions(false);
                    }
                },

                onChange: function (value) {
                    if (value) {

                        //const datos = articuloMap.get(value);
                        const datos = this.options[value];

                        if (datos) {
                            document.querySelector('#ItemName').value = datos.itemName || '';
                        }
                        listarLotesArticulo(value);

                        this.close();
                        this.blur();

                    } else {
                        document.querySelector('#ItemName').value = '';
                        inicializarSlimSelectLote([]);
                        limpiarCamposLote();
                    }
                },
                onBlur: function () {
                    this.clearOptions();

                }
            });
        }

        // ==========================================
        // 4. LÓGICA SLIMSELECT (LOTES)
        // ==========================================
        async function listarLotesArticulo(ItemCode) {
            try {
                const response = await fetch(`/Documentos/SelectLotesArticulo?ItemCode=${ItemCode}`);
                const data = await response.json();
                if (!data || data.error) {
                    inicializarSlimSelectLote([]);
                    return;
                }
                const opciones = [
                    { text: '', value: '', placeholder: true },
                    ...data.map(l => ({
                        text: l.text,
                        value: l.value,
                        data: { mnfSerial: l.mnfSerial, expDate: l.expDate }
                    }))
                ];
                inicializarSlimSelectLote(opciones);
            } catch (error) {
                console.error(error);
                inicializarSlimSelectLote([]);
            }
        }

        function inicializarSlimSelectLote(dataOpciones) {
            const selectElement = document.querySelector('#DistNumber');
            if (slimLote) slimLote.destroy();

            slimLote = new SlimSelect({
                select: selectElement,
                data: dataOpciones,
                settings: {
                    placeholderText: 'Seleccione Lote',
                    searchText: 'No encontrado',
                    allowDeselect: true
                },
                events: {
                    afterChange: async (newVal) => {
                        const seleccion = newVal[0];
                        if (seleccion && seleccion.value && seleccion.value !== '') {
                            const datosExtra = seleccion.data;
                            document.querySelector('#MnfSerial').value = datosExtra.mnfSerial || '';
                            document.querySelector('#ExpDate').value = datosExtra.expDate || '';

                            const itemCode = document.querySelector('#ItemCode').value;
                            if (itemCode) {
                                const existe = await verificarLoteRegistrado(itemCode, seleccion.value);
                                if (existe) {
                                    Swal.fire({
                                        icon: 'warning',
                                        title: 'Protocolo existente',
                                        text: 'Ya existe un protocolo para este lote. ¿Desea continuar?',
                                        showCancelButton: true,
                                        confirmButtonText: 'Sí',
                                        cancelButtonText: 'No'
                                    }).then((result) => {
                                        if (!result.isConfirmed) {
                                            slimLote.setSelected([]);
                                            limpiarCamposLote();
                                        }
                                    });
                                }
                            }
                        } else {
                            limpiarCamposLote();
                        }
                    }
                }
            });
        }

        // ==========================================
        // 5. FUNCIONES AUXILIARES & MODALES
        // ==========================================
        function initDataTable() {
            if ($.fn.DataTable.isDataTable('#tablaProtocolos')) {
                $('#tablaProtocolos').DataTable().destroy();
            }
            $('#tablaProtocolos').DataTable({
                language: { url: "https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json" },
                responsive: true,
                pageLength: 10
            });
        }

        function abrirModalCrearProtocolo() {
            const modal = new bootstrap.Modal(document.getElementById('modalCrearProtocolo'));
            modal.show();
        }

        function limpiarCamposLote() {
            if (document.querySelector('#MnfSerial')) document.querySelector('#MnfSerial').value = '';
            if (document.querySelector('#ExpDate')) document.querySelector('#ExpDate').value = '';
        }

        async function verificarLoteRegistrado(itemCode, lote) {
            try {
                const resp = await fetch(`/Documentos/VerificarLote?itemCode=${encodeURIComponent(itemCode)}&lote=${encodeURIComponent(lote)}`);
                const data = await resp.json();
                return data.registrado === true;
            } catch (e) { return false; }
        }

        function eliminarProtocolo(itemCode, distNumber, btn) {
             Swal.fire({
                title: '¿Eliminar?',
                text: `${itemCode} - ${distNumber}`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("EliminarProtocoloAjax", "Documentos")',
                        { itemCode: itemCode, distNumber: distNumber },
                        function (res) {
                            if (res.success) {
                                Swal.fire('Eliminado', res.message, 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Error', res.message, 'error');
                            }
                        }
                    ).fail(function () {
                        Swal.fire('Error', 'No se pudo conectar con el servidor', 'error');
                    });
                }
            });
        }

        // --- FILTROS ---
        function abrirModalFiltros() {
  const el = document.getElementById('modalProtocolo');
    const modal = bootstrap.Modal.getOrCreateInstance(el);
  modal.show();
}

async function aplicarFiltros(reset = false) {
    const params = new URLSearchParams({
   ItemCode: reset ? "" : (document.getElementById("filtroCodigo")?.value || ""),
