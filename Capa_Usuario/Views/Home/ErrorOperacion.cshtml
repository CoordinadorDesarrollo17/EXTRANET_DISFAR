@{
    ViewBag.Title = "ErrorOperacion";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container mt-5 text-center">
    <div class="card shadow-lg border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill"></i> Acceso Denegado
            </h3>
        </div>
        <div class="card-body">
            <p class="lead mb-4">
                Sesion expirada vuelva a loguearse.
            </p>
            <a href="@Url.Action("CerrarSesion", "Usuario")" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-arrow-left-circle"></i> Regresar
            </a>
        </div>
    </div>
</div>