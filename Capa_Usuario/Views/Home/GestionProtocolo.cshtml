@model Capa_Entidad.Inventario_ENT.TablasSql.Protocolos_E
@{
    ViewBag.Title = "GestionProtocolo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>
    function listarArticulos(dom) {
        completaCampos(dom);
        if ($(dom).val().length > 3) {
            $.ajax('/Home/DataListArticulos',
                {
                    data: { "ItemName": $(dom).val(), "FirmCode": $("#FirmCode").val() },
                    dataType: 'html',
                    cache: false,
                    type: 'post',
                })
                .done(function (response) {
                    $('#listaArticulos').html(response);
                });
        }
    }
    function listarLotesArticulo(ItemCode) {
        $.ajax('/Home/SelectLotesArticulo',
            {
                data: { "ItemCode": ItemCode },
                dataType: 'html',
                cache: false,
                type: 'post',
            })
            .done(function (response) {
                $('#DistNumber').html(response);
            });
    }
    function completaCampos(dom) {
        var FirmCode = $("#listaArticulos option[value='" + $(dom).val() + "']").attr("FirmCode")
        var ItemName = $("#listaArticulos option[value='" + $(dom).val() + "']").attr("ItemName")
        $("#ItemName").val(ItemName);
        $("#FirmCode").val(FirmCode);
        $("#MnfSerial").val("");
        $("#ExpDate").val("");
        listarLotesArticulo($(dom).val());
    }
    function completaCampos2(dom) {
        var MnfSerial = $("#DistNumber option[value='" + $(dom).val() + "']").attr("MnfSerial")
        var ExpDate = $("#DistNumber option[value='" + $(dom).val() + "']").attr("ExpDate")
        $("#MnfSerial").val(MnfSerial);
        $("#ExpDate").val(ExpDate);
    }
</script>
<style>
    table {
        text-align: center;
    }
    td {
        padding: 10px;
        font-size: 14px;
    }
</style>
<a style="float:left;" href="@Url.Action("GestionDocumentos", "Home")" class="btn btn-secondary">
    <i class="icon-arrow-bold-left"></i>
    <span>Regresar</span>
</a>
<br />
<br />
<div id="bodyform">
    <div class="m-0 row justify-content-center align-items-center">
        @using (Html.BeginForm("GestionProtocolo", "Home", FormMethod.Post, new { @enctype = "multipart/form-data" }))
        {
            <h5 id="resaltado">Protocolos de Producto</h5>
            <table>
                <tr>
                    <td>
                        <input type="search" name="ItemCode" id="ItemCode" list="listaArticulos" oninput="listarArticulos(this); completaCampos(this)" autocomplete="off" class="form-control" placeholder="Buscar artículo*" />
                        <datalist id="listaArticulos"></datalist>
                        <input type="text" name="ItemName" id="ItemName" readonly class="form-control" placeholder="Nombre de articulo" />
                        <input type="hidden" name="FirmCode" id="FirmCode" readonly />
                    </td>
                </tr>
                <tr>
                    <td>
                        <input type="search" name="DistNumber" list="DistNumber" class="form-control" onchange="completaCampos2(this);" autocomplete="off" placeholder="Seleccione o ingrese lote*" />
                        <datalist id="DistNumber"></datalist>
                        <input name="MnfSerial" id="MnfSerial" class="form-control" placeholder="Registro de articulo" />
                        <input type="date" name="ExpDate" id="ExpDate" class="form-control" placeholder="Fecha de expiracion de articulo" />
                    </td>
                </tr>
                <tr>
                    <td><input accept=".pdf" class="form-control" id="ArchivoPdf" name="ArchivoPdf" type="file" value=""></td>
                </tr>
                <tr>
                    <td>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Cargar Archivo
                        </button>
                    </td>
                </tr>
            </table>
        }
        <p id="advertencias">*Debe elegir producto y lote obligatoriamente. <br /> Solo se admite la carga de archivos .pdf (10 MB max.)</p>
    </div>
</div>
<script>
       if ('@ViewBag.mensaje' != "") {
       swal.fire({
           title: "@ViewBag.mensaje",
           text: "Verifique campos",
           icon: "warning"
       })
       };
</script>