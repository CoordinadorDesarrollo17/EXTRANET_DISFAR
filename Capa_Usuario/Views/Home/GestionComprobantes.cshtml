@model IEnumerable<Capa_Entidad.Transacciones_ENT.TablasSql.Factura_E>
@{
    ViewBag.Title = "GestionComprobantes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .buton {
        width: 60px;
        color: black;
        text-decoration: none;
        padding: 2px 5px 2px 5px;
        border: 2px solid red;
        float: right;
        border-radius: 9px;
    }
    #cajas .contenedor {
        float: left;
        max-width: 370px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
    }
    #cajas table {
        margin: 15px;
        max-width: 100%;
        background-color:white;
        padding: 10px;
    }
    #cajas td {
        text-align: left;
        font-size: 14px;
    }
</style>
<a style="float:left;" href="@Url.Action("SesionUsuario", "Home")" class="btn btn-secondary">
    <i class="icon-arrow-bold-left"></i>
    <span>Regresar</span>
</a>
<br />
<br />
<a style="float:left;" href="@Url.Action("ConsultarComprobantes", "Home")" class="btn btn-warning font-weight-bold">
    <i class="bi bi-search"></i>  <span>Nueva Busqueda</span>
</a>
<br />
<br />
    @foreach (var item in Model)
    {
        <div id="cajas">
            <div class="contenedor">
                <table class="table table-sm">
                    <tr>
                        <td style="font-weight:700">
                            @if (item.Correlativo.Substring(0, 2) == "01")
                            {@Html.DisplayName("Factura Electronica") }
                        else if (item.Correlativo.Substring(0, 2) == "03")
                        { @Html.DisplayName("Boleta")}
                        </td>
                    </tr>
                    <tr>
                        <td hidden>
                            @Html.DisplayFor(modelItem => item.DocEntry)
                        </td>
                        <td>
                            @Html.DisplayName("Serie y Numero")
                            <label style="font-weight:700; float:right">
                                @Html.DisplayFor(modelItem => item.Correlativo)
                            </label>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            @Html.DisplayName("Fecha de contabilizacion")
                            <label style="font-weight:700; float:right">
                                @item.DocDate
                            </label>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <span style="color:blue; font-weight:700"> S./@Html.DisplayFor(modelItem => item.DocTotal)</span>
                            @Html.ActionLink("Detalle", "DetalleComprobante", new { id = item.DocEntry }, new { @class = "btn-sm btn-success pull-right" })
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    }
